# Kopyalayın: cp .env.example .env
# .env Git'e eklenmez (.gitignore). Üretimde güçlü değerler kullanın.

# Oturum imzası — en az 32 karakter rastgele metin
SESSION_SECRET=degistirin-uzun-rastgele-bir-metin

# HTTPS üretimde: true — Sadece http://localhost denemesi: false
COOKIE_SECURE=false

# İlk kurulumda DB boşsa oluşacak admin şifresi
ADMIN_PASSWORD=admin123

# Postgres — db ve app aynı değeri kullanır.
# ÖNEMLİ: pgdata volume bir kez oluştuktan sonra burayı değiştirmek DB şifresini değiştirmez;
# uyuşmazlıkta "password authentication failed" alırsınız — ya eski şifreyi yazın ya da volume'u silip yeniden kurun.
POSTGRES_PASSWORD=muhasebe
# Uygulama dışarıda 3006 (docker-compose.yml). Başka port için compose dosyasını düzenleyin
