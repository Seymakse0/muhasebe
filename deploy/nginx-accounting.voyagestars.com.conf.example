# Örnek: /etc/nginx/sites-available/ içine kopyalayıp server_name ve proxy_pass portunu düzenleyin.
# sudo ln -s ... sites-enabled/ && sudo nginx -t && sudo systemctl reload nginx
#
# Docker .env: APP_PORT=3006 → aşağıdaki 3006 ile aynı olmalı.

server {
    listen 80;
    server_name accounting.voyagestars.com;

    location / {
        proxy_pass http://127.0.0.1:3006;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
